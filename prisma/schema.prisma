// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STATION_LEADER
  PREP_KITCHEN
  STAFF
}

enum UserStatus {
  ACTIVE
  ONBOARDING
  INACTIVE
}

model Tenant {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  active_modules Json            @default("{}") // Ex: {"production": true, "inventory": true}
  max_employees  Int             @default(10)
  created_at     DateTime        @default(now())

  users          User[]
  userProfiles   UserProfile[]
  stations       Station[]
  shiftHandovers ShiftHandover[]
  prepItems      PrepItem[]
  productionLogs ProductionLog[]
  prepItemRequests PrepItemRequest[]
  recipes        Recipe[]
  kitchenTools   KitchenTool[]
  checklists     Checklist[]
  checklistCompletions ChecklistCompletion[]
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  clerk_user_id  String          @unique
  tenant_id      String          @db.Uuid
  role           UserRole
  profile_id     String?         @db.Uuid
  name           String
  email          String
  status         UserStatus      @default(ONBOARDING)
  created_at     DateTime        @default(now())

  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  profile        UserProfile?    @relation(fields: [profile_id], references: [id], onDelete: SetNull)
  shiftHandovers   ShiftHandover[]
  productionLogs   ProductionLog[]
  prepItemRequests PrepItemRequest[]
  recipeComments   RecipeComment[]
  createdChecklists  Checklist[]
  checklistCompletions ChecklistCompletion[]
}

model UserProfile {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_id       String   @db.Uuid
  name            String
  base_role       UserRole @default(STAFF)
  allowed_modules Json     @default("{}")
  created_at      DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users       User[]
  checklists  Checklist[]

  @@unique([tenant_id, name])
}

model Station {
  id             String          @id @default(uuid()) @db.Uuid
  tenant_id      String          @db.Uuid
  name           String
  icon           String?         @default("UtensilsCrossed")
  created_at     DateTime        @default(now())

  tenant           Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  prepItems        PrepItem[]
  shiftHandovers   ShiftHandover[]
  prepItemRequests PrepItemRequest[]

  @@unique([tenant_id, name])
}

model PrepItem {
  id             String          @id @default(uuid()) @db.Uuid
  tenant_id      String          @db.Uuid
  name           String
  unit           String
  target_quantity Float
  created_at     DateTime        @default(now())

  tenant         Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  stations       Station[]
  handoverItemCounts HandoverItemCount[]
  productionLogs ProductionLog[]
  dayTargets     PrepItemDayTarget[]
  requestSource  PrepItemRequest?
  recipeIngredients RecipeIngredient[]

  @@unique([tenant_id, name], name: "tenantId_name")
}

model ShiftHandover {
  id             String          @id @default(uuid()) @db.Uuid
  tenant_id      String          @db.Uuid
  user_id        String          @db.Uuid
  station_id     String          @db.Uuid
  note           String?
  created_at     DateTime        @default(now())

  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [user_id], references: [id])
  station        Station         @relation(fields: [station_id], references: [id])
  items          HandoverItemCount[]
  productionLogs ProductionLog[]
}

model HandoverItemCount {
  id                 String          @id @default(uuid()) @db.Uuid
  shift_handover_id  String          @db.Uuid
  prep_item_id       String          @db.Uuid
  actual_quantity    Float

  shiftHandover      ShiftHandover   @relation(fields: [shift_handover_id], references: [id], onDelete: Cascade)
  prepItem           PrepItem        @relation(fields: [prep_item_id], references: [id])

  @@unique([shift_handover_id, prep_item_id])
}

model ProductionLog {
  id                 String          @id @default(uuid()) @db.Uuid
  tenant_id          String          @db.Uuid
  prep_item_id       String          @db.Uuid
  user_id            String          @db.Uuid
  shift_handover_id  String          @db.Uuid
  produced_quantity  Float
  created_at         DateTime        @default(now())

  tenant             Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  prepItem           PrepItem        @relation(fields: [prep_item_id], references: [id])
  user               User            @relation(fields: [user_id], references: [id])
  shiftHandover      ShiftHandover   @relation(fields: [shift_handover_id], references: [id])
}

model PrepItemDayTarget {
  id                 String          @id @default(uuid()) @db.Uuid
  prep_item_id       String          @db.Uuid
  day_of_week        Int             // 0-6
  target_quantity    Float

  prepItem           PrepItem        @relation(fields: [prep_item_id], references: [id], onDelete: Cascade)

  @@unique([prep_item_id, day_of_week])
}

model PrepItemRequest {
  id                 String          @id @default(uuid()) @db.Uuid
  tenant_id          String          @db.Uuid
  user_id            String          @db.Uuid
  station_id         String          @db.Uuid
  name               String
  unit               String
  note               String?
  status             RequestStatus    @default(PENDING)
  created_at         DateTime        @default(now())
  
  // Se aprovado, liga ao item criado
  prep_item_id       String?         @unique @db.Uuid
  
  tenant             Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user               User            @relation(fields: [user_id], references: [id])
  station            Station         @relation(fields: [station_id], references: [id])
  prepItem           PrepItem?       @relation(fields: [prep_item_id], references: [id])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChecklistFrequency {
  DAILY
  SPECIFIC_DAYS
}

enum TimeSlot {
  ALL_DAY
  OPENING
  MIDDAY
  CLOSING
}

enum RecipeCategory {
  PRIMARY       // Produtos primários
  MANIPULATED   // Produtos manipulados (ovo cozido, muzzarella ralada, etc.)
  INTERMEDIATE  // Produtos intermediários (massa de pizza, etc.)
  FINAL         // Produtos finais
}

model Recipe {
  id              String              @id @default(uuid()) @db.Uuid
  tenant_id       String              @db.Uuid
  name            String
  description     String?
  category        RecipeCategory
  base_yield      Float               // Ex: 10 (porções), 2 (kg)
  yield_unit      String              // Ex: "porções", "kg"
  photo_url       String?
  allowed_profile_ids String[]  @default([])
  required_tools  String[]    @default([])
  chefs_tip       String?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt

  tenant           Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  ingredients      RecipeIngredient[]
  steps            RecipeStep[]
  comments         RecipeComment[]
  usedAsIngredient RecipeIngredient[]  @relation("IngredientSource")

  @@unique([tenant_id, name])
}

model KitchenTool {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, name])
}

model RecipeIngredient {
  id               String    @id @default(uuid()) @db.Uuid
  recipe_id        String    @db.Uuid
  prep_item_id     String?   @db.Uuid
  source_recipe_id String?   @db.Uuid
  quantity         Float
  unit             String
  sort_order       Int       @default(0)

  recipe           Recipe    @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  prepItem         PrepItem? @relation(fields: [prep_item_id], references: [id])
  sourceRecipe     Recipe?   @relation("IngredientSource", fields: [source_recipe_id], references: [id])
}

model RecipeStep {
  id               String    @id @default(uuid()) @db.Uuid
  recipe_id        String    @db.Uuid
  step_number      Int
  instruction      String

  recipe           Recipe    @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@unique([recipe_id, step_number])
}

model RecipeComment {
  id               String    @id @default(uuid()) @db.Uuid
  recipe_id        String    @db.Uuid
  user_id          String    @db.Uuid
  text             String
  created_at       DateTime  @default(now())

  recipe           Recipe    @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [user_id], references: [id])
}

// ─── Checklists ──────────────────────────────────────────────

model Checklist {
  id              String    @id @default(uuid()) @db.Uuid
  tenant_id       String    @db.Uuid
  name            String
  description     String?
  is_active       Boolean   @default(true)
  created_by      String    @db.Uuid
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  creator         User      @relation(fields: [created_by], references: [id])
  tasks           ChecklistTask[]
  profiles        UserProfile[]

  @@unique([tenant_id, name])
}

model ChecklistTask {
  id              String             @id @default(uuid()) @db.Uuid
  checklist_id    String             @db.Uuid
  title           String
  description     String?
  frequency       ChecklistFrequency @default(DAILY)
  days_of_week    Int[]              // 0=dom, 6=sáb — usado quando frequency = SPECIFIC_DAYS
  time_slot       TimeSlot           @default(ALL_DAY)
  sort_order      Int                @default(0)
  points          Int                @default(1)
  is_active       Boolean            @default(true)
  created_at      DateTime           @default(now())

  checklist       Checklist          @relation(fields: [checklist_id], references: [id], onDelete: Cascade)
  completions     ChecklistCompletion[]
}

model ChecklistCompletion {
  id              String    @id @default(uuid()) @db.Uuid
  task_id         String    @db.Uuid
  user_id         String    @db.Uuid
  tenant_id       String    @db.Uuid
  date            String    // "YYYY-MM-DD" — timezone resolvido no app
  completed_at    DateTime  @default(now())
  note            String?

  task            ChecklistTask @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [user_id], references: [id])
  tenant          Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([task_id, user_id, date])
}
